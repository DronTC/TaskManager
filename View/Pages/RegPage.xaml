<Page x:Class="TaskManager.View.Pages.RegPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TaskManager.View.Pages"
      mc:Ignorable="d" 
      Height="450" Width="350">

    <Border Background="White" CornerRadius="30">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="0.5*"/>
                <RowDefinition Height="0.5*"/>
                <RowDefinition Height="0.5*"/>
                <RowDefinition Height="0.5*"/>
                <RowDefinition Height="0.5*"/>
                <RowDefinition Height="0.5*"/>
                <RowDefinition Height="0.5*"/>
                <RowDefinition Height="0.5*"/>
                <RowDefinition Height="0.5*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="1" Margin="40, 0, 40, 10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.5*"/>
                    <ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Вход" FontSize="20"
                       FontWeight="Medium"
                       VerticalAlignment="Bottom" MouseDoubleClick="Label_MouseDoubleClick"/>
                <Label Grid.Column="1" Content="Регистрация" FontSize="20" Margin="0, 0, 0, 5"
                       FontWeight="Medium" VerticalAlignment="Bottom"/>
            </Grid>
            <TextBox Grid.Row="2" Style="{StaticResource AuthRegTextBox}"/>
            <Label Grid.Row="2" Content="Имя" Margin="55, 1, 0, 0" HorizontalAlignment="Left" VerticalAlignment="Top"
                   Foreground="Gray" Width="58" Height="24"/>
            <TextBox Grid.Row="3" Style="{StaticResource AuthRegTextBox}"/>
            <Label Grid.Row="3" Content="Фамилия" Margin="55, 1, 0, 0" HorizontalAlignment="Left" VerticalAlignment="Top"
                   Foreground="Gray" Width="58" Height="24"/>
            <TextBox Grid.Row="4" Style="{StaticResource AuthRegTextBox}"/>
            <Label Grid.Row="4" Content="E-mail" Margin="55, 1, 0, 0" HorizontalAlignment="Left" VerticalAlignment="Top"
                   Foreground="Gray" Width="41" Height="24"/>
            <PasswordBox Grid.Row="5" Style="{StaticResource AuthRegTextBox}"/>
            <Label Grid.Row="5" Content="Пароль" Margin="55, 1, 0, 0" HorizontalAlignment="Left" VerticalAlignment="Top"
                   Foreground="Gray" Width="49" Height="24"/>
            <PasswordBox Grid.Row="6" Style="{StaticResource AuthRegTextBox}"/>
            <Label Grid.Row="6" Content="Подтвердите пароль" Margin="55, 1, 0, 0" HorizontalAlignment="Left" VerticalAlignment="Top"
                   Foreground="Gray" Width="122" Height="24"/>
            <Button Name="regButton" Grid.Row="7" Content="Регистрация" Style="{StaticResource AuthRegButton}"/>
        </Grid>
    </Border>
</Page>
